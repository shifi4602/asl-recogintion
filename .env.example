# ── Auth ──────────────────────────────────────────────────────────────────────
# REQUIRED: replace before any deployment
AUTH__SECRET_KEY=CHANGE-ME-before-deploying-use-a-256-bit-random-string
AUTH__ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Data ──────────────────────────────────────────────────────────────────────
# DATA__RAW_DIR=data/asl_alphabet_train
# DATA__SPLIT_DIR=data/split

# ── Kaggle credentials (required for automatic download) ─────────────────────
# KAGGLE_USERNAME=your_username
# KAGGLE_KEY=your_api_key

# ── Model ─────────────────────────────────────────────────────────────────────
# MODEL__BACKBONE=mobilenet_v2
# MODEL__SAVE_DIR=models

# ── Training ──────────────────────────────────────────────────────────────────
# TRAINING__MLFLOW_TRACKING_URI=http://localhost:5000

# ── API ───────────────────────────────────────────────────────────────────────
# API__PORT=8000
# API__DEBUG=false
